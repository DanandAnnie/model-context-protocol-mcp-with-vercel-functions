              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "check-polling",
      "name": "Continue Polling?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [2000, 550]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has-overlays",
              "leftValue": "={{ $json.overlays.length }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "check-overlays",
      "name": "Has Overlays?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [2250, 200]
    },
    {
      "parameters": {
        "jsCode": "// Build Shotstack Edit JSON for video overlays\nconst input = $input.first().json;\nconst overlays = input.overlays || [];\nconst videoDuration = input.duration || 30;\n\n// Build clips array - start with the HeyGen video as background\nconst clips = [];\n\n// Main video clip\nclips.push({\n  asset: {\n    type: 'video',\n    src: input.videoUrl\n  },\n  start: 0,\n  length: videoDuration\n});\n\n// Build overlay clips\nconst overlayClips = [];\n\nfor (const overlay of overlays) {\n  const startTime = overlay.startTime || 0;\n  const endTime = overlay.endTime || videoDuration;\n  const duration = endTime - startTime;\n  \n  if (overlay.type === 'text') {\n    // Text overlay\n    overlayClips.push({\n      asset: {\n        type: 'title',\n        text: overlay.text || 'Sample Text',\n        style: overlay.style || 'minimal',\n        color: overlay.color || '#ffffff',\n        size: overlay.size || 'medium',\n        background: overlay.background || null,\n        position: overlay.position || 'bottom'\n      },\n      start: startTime,\n      length: duration,\n      position: overlay.position || 'bottom',\n      offset: {\n        x: overlay.xOffset || 0,\n        y: overlay.yOffset || -0.35\n      },\n      transition: overlay.transition || null\n    });\n    \n  } else if (overlay.type === 'image' || overlay.type === 'logo') {\n    // Image/Logo overlay\n    overlayClips.push({\n      asset: {\n        type: 'image',\n        src: overlay.src || overlay.url\n      },\n      start: startTime,\n      length: duration,\n      fit: overlay.fit || 'none',\n      scale: overlay.scale || 0.2,\n      position: overlay.position || 'topRight',\n      offset: {\n        x: overlay.xOffset || -0.05,\n        y: overlay.yOffset || 0.05\n      },\n      opacity: overlay.opacity || 1\n    });\n    \n  } else if (overlay.type === 'lowerThird') {\n    // Lower third title\n    overlayClips.push({\n      asset: {\n        type: 'title',\n        text: overlay.text || 'Speaker Name',\n        style: 'blockbuster',\n        color: overlay.color || '#ffffff',\n        size: 'small'\n      },\n      start: startTime,\n      length: duration,\n      position: 'bottomLeft',\n      offset: {\n        x: 0.1,\n        y: -0.1\n      },\n      transition: {\n        in: 'slideLeft',\n        out: 'slideLeft'\n      }\n    });\n    \n  } else if (overlay.type === 'caption') {\n    // Caption/subtitle overlay\n    overlayClips.push({\n      asset: {\n        type: 'title',\n        text: overlay.text,\n        style: 'subtitle',\n        color: overlay.color || '#ffffff',\n        size: 'small',\n        background: '#000000'\n      },\n      start: startTime,\n      length: duration,\n      position: 'bottom',\n      offset: {\n        x: 0,\n        y: -0.1\n      }\n    });\n  }\n}\n\n// Build the Shotstack edit payload\nconst editPayload = {\n  timeline: {\n    background: '#000000',\n    tracks: [\n      {\n        clips: overlayClips\n      },\n      {\n        clips: clips\n      }\n    ]\n  },\n  output: {\n    format: 'mp4',\n    resolution: 'hd',\n    fps: input.fps || 25\n  }\n};\n\nconst shotstackBaseUrl = input.shotstackStage === 'v1' \n  ? 'https://api.shotstack.io/v1'\n  : 'https://api.shotstack.io/stage';\n\nreturn {\n  json: {\n    videoId: input.videoId,\n    originalVideoUrl: input.videoUrl,\n    overlays: input.overlays,\n    editPayload,\n    shotstackBaseUrl\n  }\n};"
      },
      "id": "build-shotstack-edit",
      "name": "Build Shotstack Edit",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2500, 100]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $json.shotstackBaseUrl }}/render",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
