    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst previousData = $('Build Shotstack Edit').first().json;\n\nif (!response.success || !response.response?.id) {\n  throw new Error('Shotstack render submission failed');\n}\n\nreturn {\n  json: {\n    renderId: response.response.id,\n    ...previousData,\n    shotstackPollCount: 0,\n    shotstackMaxPolls: 120\n  }\n};"
      },
      "id": "extract-render-id",
      "name": "Extract Render ID",
      "type": "n8n-nodes-base.code",
