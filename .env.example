# PropertyRadar MCP Server - Environment Variables
# Copy this to .env and fill in your API keys

# ── Required ──────────────────────────────────────────────────
# PropertyRadar API Token (get from https://app.propertyradar.com/settings/api)
PROPERTY_RADAR_API_TOKEN=

# ── Optional (enhance data coverage) ─────────────────────────
# RapidAPI Key for Zillow Zestimate data (get from https://rapidapi.com)
RAPIDAPI_KEY=

# ATTOM Data API Key (get from https://api.gateway.attomdata.com)
ATTOM_API_KEY=

# US Census Bureau API Key (get from https://api.census.gov/data/key_signup.html)
# Works without a key at lower rate limits
CENSUS_API_KEY=

# HUD User API Key for Fair Market Rent data (get from https://www.huduser.gov/hudapi/public/register)
HUD_API_KEY=
