    {
      "parameters": {
        "method": "GET",
        "url": "={{ $json.shotstackBaseUrl }}/render/{{ $json.renderId }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
