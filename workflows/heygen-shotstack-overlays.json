      "id": "submit-shotstack",
      "name": "Submit to Shotstack",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2750, 100],
      "credentials": {
        "httpHeaderAuth": {
          "id": "shotstack-api-key",
          "name": "Shotstack API Key"
        }
