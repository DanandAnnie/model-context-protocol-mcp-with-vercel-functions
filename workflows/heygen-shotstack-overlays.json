      "id": "check-shotstack-status",
      "name": "Check Shotstack Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [3500, 100],
      "credentials": {
        "httpHeaderAuth": {
          "id": "shotstack-api-key",
          "name": "Shotstack API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const statusResponse = $input.first().json;\nconst previousData = $('Extract Render ID').first().json;\n\nconst status = statusResponse.response?.status;\nconst url = statusResponse.response?.url;\nconst pollCount = previousData.shotstackPollCount + 1;\n\nreturn {\n  json: {\n    ...previousData,\n    shotstackPollCount: pollCount,\n    shotstackStatus: status,\n    processedVideoUrl: url,\n    isRenderComplete: status === 'done',\n    isRenderFailed: status === 'failed',\n    shouldContinueShotstackPolling: ['queued', 'fetching', 'rendering', 'saving'].includes(status) && pollCount < previousData.shotstackMaxPolls\n  }\n};"
      },
      "id": "process-shotstack-status",
      "name": "Process Shotstack Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3750, 100]
