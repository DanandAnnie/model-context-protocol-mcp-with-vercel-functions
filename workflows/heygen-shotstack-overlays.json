        },
        "options": {}
      },
      "id": "check-shotstack-polling",
      "name": "Continue Shotstack Polling?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [4000, 350]
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nreturn {\n  json: {\n    success: true,\n    videoId: input.videoId,\n    originalVideoUrl: input.originalVideoUrl,\n    processedVideoUrl: input.processedVideoUrl,\n    overlaysApplied: input.overlays,\n    renderEngine: 'shotstack'\n  }\n};"
      },
      "id": "format-success",
      "name": "Format Success Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [4250, 0]
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nreturn {\n  json: {\n    success: true,\n    videoId: input.videoId,\n    originalVideoUrl: input.videoUrl,\n    processedVideoUrl: input.videoUrl,\n    overlaysApplied: [],\n    message: 'No overlays requested - returning original video'\n  }\n};"
      },
      "id": "return-original",
      "name": "Return Original Video",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2500, 300]
    },
    {
      "parameters": {
        "jsCode": "return {\n  json: {\n    success: false,\n    error: 'Video generation or rendering failed',\n    details: $json\n  }\n};"
